---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section>
    <div class="container">
      <h1 class="page-title">About Me</h1>

      <div class="about-content">
        <div class="about-text">
          <p>
            I'm a Senior Web Developer with deep expertise in <strong>Ruby on Rails</strong> and 
            a strong track record of building scalable, maintainable web applications. Over the 
            years, I've worked across the full stack — from database design and API architecture 
            to front-end integration and deployment.
          </p>
          <p>
            I specialize in <strong>API Integration</strong>, where I've built 
            numerous integrations connecting diverse systems with third-party APIs, automating 
            workflows, and extending platform capabilities. My experience spans RESTful API design, 
            payment gateway integration (Stripe), and background job processing.
          </p>
          <p>
            I have extensive experience in deployment and infrastructure — from setting up servers 
            from scratch on <strong>DigitalOcean</strong> to deploying with <strong>Kamal</strong>. 
            I often <strong>dockerize legacy apps to work on newer machines for compatibility issues</strong>, 
            ensuring older software remains functional on modern infrastructure.
          </p>
          <p>
            I enjoy tackling complex problems, writing clean and testable code, and building 
            products that make a real difference for users and businesses.
          </p>
        </div>

        <div class="about-skills">
          <h3>Core Skills</h3>
          <div class="skill-group">
            <h4>Backend</h4>
            <div class="skill-tags">
              <span>Ruby on Rails</span>
              <span>PostgreSQL</span>
              <span>Elasticsearch</span>
              <span>Sidekiq</span>
              <span>REST API</span>
            </div>
          </div>
          <div class="skill-group">
            <h4>Integrations / API</h4>
            <div class="skill-tags">
              <span>API Integration</span>
              <span>REST &amp; GraphQL API</span>
              <span>Stripe</span>
            </div>
          </div>
          <div class="skill-group">
            <h4>Frontend</h4>
            <div class="skill-tags">
              <span>HTML/CSS</span>
              <span>JavaScript</span>
              <span>Stimulus</span>
              <span>Hotwire</span>
            </div>
          </div>
          <div class="skill-group">
            <h4>DevOps</h4>
            <div class="skill-tags">
              <span>Linux</span>
              <span>Docker</span>
              <span>Nginx</span>
              <span>Kamal</span>
              <span>DigitalOcean</span>
              <span>Server Setup</span>
              <span>Git</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .about-content {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .about-text strong {
    color: var(--text-primary);
  }

  .about-skills h3 {
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
  }

  .skill-group {
    margin-bottom: 1.5rem;
  }

  .skill-group h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tags span {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .about-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
