---
import type { Project } from '../data/projects';
import { slugify } from '../lib/slugify';

export interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

const anchorId = slugify(project.title);
---

<article class="project-card" id={anchorId}>
  <div class="project-number">0{index + 1}</div>
  <div class="project-content">
    <h3 class="project-title">
      <a href={`#${anchorId}`} class="anchor-link" aria-label="Link to this project">#</a>
      {project.title}
    </h3>
    <span class="project-date">{project.dateRange}</span>
    <p class="project-desc">{project.longDescription}</p>
    <div class="project-tags">
      {project.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <ul class="project-highlights">
      {project.highlights.map((h) => <li>{h}</li>)}
    </ul>
    {project.link && (
      <a href={project.link} class="project-link" target="_blank" rel="noopener noreferrer">
        Upwork Job →
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 80px;
  }

  .project-card:target {
    background: rgba(212, 165, 116, 0.05);
    border-radius: 8px;
    margin-left: -1rem;
    margin-right: -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-color: var(--accent);
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-number {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    min-width: 3rem;
  }

  .project-content {
    flex: 1;
  }

  .project-title {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .anchor-link {
    color: var(--text-muted);
    opacity: 0;
    margin-right: 0.35rem;
    font-size: 0.9em;
    transition: opacity 0.2s, color 0.2s;
    text-decoration: none;
  }

  .project-title:hover .anchor-link {
    opacity: 1;
  }

  .anchor-link:hover {
    color: var(--accent);
  }

  .project-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 1rem;
  }

  .project-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--accent);
    background: rgba(212, 165, 116, 0.1);
    border: 1px solid rgba(212, 165, 116, 0.2);
    border-radius: 4px;
  }

  .project-highlights {
    list-style: none;
    padding: 0;
  }

  .project-highlights li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding: 0.25rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .project-highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .project-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(212, 165, 116, 0.2);
    border-radius: 4px;
    transition: background 0.2s;
  }

  .project-link:hover {
    background: rgba(212, 165, 116, 0.1);
  }

  @media (max-width: 768px) {
    .project-card {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
